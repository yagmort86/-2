{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api?__path=:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/client/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/viewer/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/tg",
      "destination": "/index.html"
    },
    {
      "source": "/telegram",
      "destination": "/index.html"
    }
  ]
}
